# SpatialMind_Backend/.env.example
# Copy thành .env và điền thông tin thật

GEMINI_API_KEY=your_gemini_api_key_here

# Gmail SMTP (cho email notification)
# Bước 1: Bật 2-Step Verification trong Google Account
# Bước 2: Vào Security -> App Passwords -> Tạo password mới cho "Mail"
# Bước 3: Dùng App Password (16 ký tự) - KHÔNG dùng mật khẩu thường!
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# URL của frontend (dùng trong email template)
APP_URL=https://your-domain.com

# Secret cho cron job (đổi thành chuỗi ngẫu nhiên dài)
CRON_SECRET=change_this_to_a_long_random_string
